{
    "title": "Content Metadata",
    "type": "object",
    "properties": {
        "date": {
            "type": "integer",
            "description": "The date of the content"
        },
        "title": {
            "type": "string",
            "description": "The content title or filename"
        },
        "description": {
            "type": "string",
            "description": "The content description"
        },
        "uri": {
            "type": "string",
            "description": "The content for this asset"
        },
        "beneficiary": {
            "type": "string",
            "description": "The beneficiary content splitter"
        },
        "cost": {
            "type": "integer",
            "description": "The cost of the content in USD"
        },
        "fee": {
            "type": "integer",
            "description": "The royalty fee"
        },
        "max": {
            "type": "integer",
            "description": "The max number of times the content may be minted"
        },
        "performers": {
            "type": "array",
            "description": "The token ids of the performers in the content"
        },
        "signatures": {
            "type": "array",
            "description": "The signatures of the performers in the content"
        },
        "director": {
            "type": "string",
            "description": "The content director"
        },
        "producer": {
            "type": "string",
            "description": "The content producer"
        },
        "location": {
            "type": "integer",
            "description": "The location of the content"
        },
        "tags": {
            "type": "array",
            "description": "The tags used to identify the content"
        }
    },
    "required": ["title", "uri", "performers"]
}
